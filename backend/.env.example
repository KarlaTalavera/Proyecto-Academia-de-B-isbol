# ── Base de Datos ─────────────────────────────────────────────
# Servidor donde está corriendo MySQL / MariaDB
DB_HOST=localhost
DB_PORT=3306

# Usuario y contraseña de MySQL (el que usas para entrar a phpMyAdmin o HeidiSQL)
DB_USER=root
DB_PASSWORD=

# Nombre de la base de datos (debe existir, ver README)
DB_NAME=liga_diamante

# ── Seguridad JWT ─────────────────────────────────────────────
# Cadena secreta para firmar los tokens de sesión.
# Puede ser cualquier texto largo y aleatorio — NO lo compartas.
# Ejemplo rápido para generar uno:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=pon_aqui_cualquier_texto_largo_y_aleatorio_minimo_32_caracteres
JWT_EXPIRES_IN=8h

# ── Servidor ──────────────────────────────────────────────────
PORT=3000

# ── (Opcional) URL del frontend para CORS ─────────────────────
# Solo cambia esto si el frontend corre en un puerto distinto al 5173
FRONTEND_URL=http://localhost:5173

# ── (Opcional) Clave de API de Anthropic para perfiles IA ─────
# Solo necesaria si quieres usar la función de perfil IA de jugadores
# ANTHROPIC_API_KEY=
